# Picks up the sysext image and triggers its mount unit if it is attached.

ACTION=="add", SUBSYSTEM=="block", ENV{ID_FS_LABEL}=="kde-openqa-ext", TAG+="systemd", ENV{SYSTEMD_WANTS}+="run-extensions-openqa.mount"
