import sys
import struct
import os
import subprocess

FLATPAK_APP_ID = "io.github.dosbox-staging"
FLATPAK_REMOTE = "flathub"

def ensure_flatpak_installed():
    """Check if the Flatpak is installed; if not, install it interactively."""
    result = subprocess.run(
        ["flatpak", "info", FLATPAK_APP_ID],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL
    )
    if result.returncode == 0:
        return True

    # Install the Flatpak interactively; let its output go to the user
    install_result = subprocess.run(
        ["flatpak", "install", "--user", FLATPAK_REMOTE, FLATPAK_APP_ID]
    )
    return install_result.returncode == 0

def main():
    if len(sys.argv) < 2:
        sys.exit(1)

    path = sys.argv[1]

    # .bat files are always handled by DOSBox (no PE check needed)
    if not path.lower().endswith('.bat'):
        with open(path, 'rb') as f:
            if f.read(2) == b'MZ':
                f.seek(0x3c)
                off = struct.unpack('<I', f.read(4))[0]
                f.seek(off)
                if f.read(4) == b'PE\x00\x00':
                    sys.stderr.write("Windows PE binary – cannot run under DOSBox.\n")
                    sys.exit(1)

    # Ensure Flatpak is available
    if not ensure_flatpak_installed():
        sys.exit(1)

    # Run the DOSBox‑Staging Flatpak
    os.execvp("flatpak", ["flatpak", "run", FLATPAK_APP_ID, path])

if __name__ == "__main__":
    main()
