#!/usr/bin/bash
# SPDX-License-Identifier: GPL-2.0-only OR GPL-3.0-only OR LicenseRef-KDE-Accepted-GPL
# SPDX-FileCopyrightText: 2025 Thomas Duckworth <tduck@filotimoproject.org>

set -eu

# Install codecs-extra at runtime - this gets around distribution restrictions on codec licensing.
# This is required for Firefox to decode certain video formats.
flatpak install --runtime -y org.freedesktop.Platform.codecs-extra

# Ensure some overrides are set for the Firefox flatpak.
# This enables hardware acceleration and VA-API video decoding on NVIDIA.
if lsmod | grep -q nvidia; then
    # Check if any NVIDIA-specific overrides aren't currently set before adding them.
    if ! flatpak override --show org.mozilla.firefox | grep -q "LIBVA_DRIVERS_PATH\|LIBVA_MESSAGING_LEVEL\|MOZ_DISABLE_RDD_SANDBOX\|NVD_BACKEND"; then
        flatpak override --filesystem=host-os \
        --env=LIBVA_DRIVERS_PATH=/run/host/usr/lib64/dri \
        --env=LIBVA_MESSAGING_LEVEL=1 \
        --env=MOZ_DISABLE_RDD_SANDBOX=1 \
        --env=NVD_BACKEND=direct org.mozilla.firefox
    fi
else 
    # Check if any NVIDIA-specific overrides are currently set before removing them.
    if flatpak override --show org.mozilla.firefox | grep -q "LIBVA_DRIVERS_PATH\|LIBVA_MESSAGING_LEVEL\|MOZ_DISABLE_RDD_SANDBOX\|NVD_BACKEND"; then
        # Remove the NVIDIA-specific overrides from the Firefox flatpak override file.
        # Sucks that there isn't a command for this. We have to edit the file directly.
        sed -i \
        -e '/^filesystems=host-os;$/d' \
        -e '/^filesystems=/s/host-os;//' \
        -e '/^NVD_BACKEND=direct$/d' \
        -e '/^LIBVA_DRIVERS_PATH=\/run\/host\/usr\/lib64\/dri$/d' \
        -e '/^LIBVA_MESSAGING_LEVEL=1$/d' \
        -e '/^MOZ_DISABLE_RDD_SANDBOX=1$/d' \
        /var/lib/flatpak/overrides/org.mozilla.firefox
        # Clean up any empty [Context] or [Environment] sections in the override file.
        sudo sed -i \
        -e ':a; N; $!ba' \
        -e 's/\[Context\][[:space:]]*\(\n\[\|$\)/\1/g' \
        -e 's/\[Environment\][[:space:]]*\(\n\[\|$\)/\1/g' \
        -e '/^[[:space:]]*$/d' \
        -e 's/^[[:space:]]*//' \
        /var/lib/flatpak/overrides/org.mozilla.firefox
        # Remove the override file if it's empty.
        if [ ! -s /var/lib/flatpak/overrides/org.mozilla.firefox ]; then
            rm -f /var/lib/flatpak/overrides/org.mozilla.firefox
        fi
    fi
fi

# Check if existing Firefox config files are identical to the ones we're about to copy in.
# If they are, exit early.
if [ -f "/var/lib/flatpak/extension/org.mozilla.firefox.systemconfig/$(uname -m)/stable/defaults/pref/00-kde-linux-default.js" ] && \
   [ -f "/var/lib/flatpak/extension/org.mozilla.firefox.systemconfig/$(uname -m)/stable/policies/policies.json" ] && \
   cmp -s "/usr/share/firefox-config/00-kde-linux-default.js" "/var/lib/flatpak/extension/org.mozilla.firefox.systemconfig/$(uname -m)/stable/defaults/pref/00-kde-linux-default.js" && \
   cmp -s "/usr/share/firefox-config/policies.json" "/var/lib/flatpak/extension/org.mozilla.firefox.systemconfig/$(uname -m)/stable/policies/policies.json"; then
    exit 0
fi

# Install the KDE Linux default Firefox config into the Firefox flatpak system config extension.
mkdir -p /var/lib/flatpak/extension/org.mozilla.firefox.systemconfig/$(uname -m)/stable/defaults/pref/
cp -rf /usr/share/firefox-config/00-kde-linux-default.js /var/lib/flatpak/extension/org.mozilla.firefox.systemconfig/$(uname -m)/stable/defaults/pref/

# Install the KDE Linux default Firefox policy into the Firefox flatpak system config extension.
# This sets DuckDuckGo as the default search engine, and installs the Plasma Browser Integration extension.
# This, however, has the unfortunate side effect of causing Firefox to show a "Your browser is being managed by your organization" message in the settings.
# See https://support.mozilla.org/en-US/kb/customizing-firefox-using-policiesjson
mkdir -p /var/lib/flatpak/extension/org.mozilla.firefox.systemconfig/$(uname -m)/stable/policies/
cp -rf /usr/share/firefox-config/policies.json /var/lib/flatpak/extension/org.mozilla.firefox.systemconfig/$(uname -m)/stable/policies/
